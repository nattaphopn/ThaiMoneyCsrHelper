{
    "manifest_version": 3,
    "name": "CSRHelper",
    "description": "CSRHelper make the Part-timer's life easier!",
    "key":"",
    "version": "2.1.1",
    "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    },
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": "logo.png"
    },
    "side_panel": {
        "default_path": "TMXCsrSidePanel/index.html"
    },
    "externally_connectable": {
    "matches": [
        "https://service.th.dev.eui.money/*",
        "https://service.th.eui.money/*"
    ]
  },
    "permissions": [
        "sidePanel",
        "contextMenus",
        "tabs",
        "scripting",
        "storage",
        "activeTab"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "content_scripts": [
        {
            "matches": [
                "https://th.admin.eui.money/*",
                "https://service.th.eui.money/*"
            ],
            "run_at": "document_start",
            "js": [
                "mgm_arcQuery.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "https://th.admin.eui.money/*"
            ],
            "run_at": "document_end",
            "js": [
                "csr.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "https://chat.line.biz/*"
            ],
            "run_at": "document_end",
            "js": [
                "line_chat_emoji.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "https://chat.line.biz/*",
        "https://th.admin.eui.money/*",
        "https://service.th.dev.eui.money/*",
        "https://service.th.eui.money/*"
    ]
}